generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  DRIVER
  ADMIN
}

enum DriverStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RentalStatus {
  PENDING_OWNER
  APPROVED
  REJECTED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum RentalSituation {
  ATIVA
  LIBERADA
  PENDENTE
}

enum RentalInspectionType {
  CHECKOUT
  CHECKIN
}

enum FuelLevel {
  EMPTY
  QUARTER
  HALF
  THREE_QUARTERS
  FULL
}

enum RentalPaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum RentalFinancialEntryType {
  RENT_PAYMENT
  SECURITY_DEPOSIT
  DISCOUNT
  EXTRA_CHARGE
  REFUND
}

enum RentalPaymentMethod {
  PIX
  CASH
  BANK_TRANSFER
  CREDIT_CARD
  DEBIT_CARD
  OTHER
}

enum ContractTime {
  DIARIO
  SEMANAL
  MENSAL
}

enum VehicleType {
  CAR
  MOTORCYCLE
}

enum VehicleHighlightTier {
  NORMAL
  BRONZE
  PRATA
  OURO
}

enum VehicleHighlightOrderStatus {
  DRAFT
  PENDING_PIX
  ACTIVE
  EXPIRED
  CANCELLED
  REJECTED
}

enum PixKeyType {
  CPF
  CNPJ
  EMAIL
  PHONE
  RANDOM
}

enum MarketplaceExposurePlacement {
  LIST
}

enum PartnerCategory {
  INSURANCE
  WORKSHOP
  BODYSHOP
  PARTS
  OTHER
}

/** Onde o app pode exibir um slot de anúncio (house / AdMob futuro). */
enum AdPlacementKey {
  DRIVER_HOME
  MARKETPLACE_LIST
}

enum AdCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
}

enum AdEventType {
  IMPRESSION
  CLICK
  DISMISS
  FILL_ERROR
}

/** Locador avalia o motorista ou o contrário (uma avaliação por direção por locação). */
enum ReviewDirection {
  OWNER_TO_DRIVER
  DRIVER_TO_OWNER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())
  /** Versão da política de privacidade aceita pelo usuário (ex.: "1"). */
  privacyPolicyVersion    String    @default("")
  privacyPolicyAcceptedAt DateTime?
  /** Versão dos termos de uso aceita pelo usuário (ex.: "1"). */
  termsOfUseVersion    String    @default("")
  termsOfUseAcceptedAt DateTime?

  ownerProfile  OwnerProfile?
  driverProfile DriverProfile?
  vehicles      Vehicle[]
  rentals       Rental[]      @relation("DriverRentals")
  vehicleDriverBlocks VehicleDriverBlock[]
  resetTokens   PasswordResetToken[]
  partners      Partner[]
  reviewsFrom   RentalReview[] @relation("ReviewFrom")
  reviewsTo     RentalReview[] @relation("ReviewTo")
  createdInspections RentalInspection[] @relation("InspectionCreatedBy")
  highlightOrdersOwned      VehicleHighlightOrder[] @relation("HighlightOrderOwner")
  highlightOrdersConfirmed  VehicleHighlightOrder[] @relation("HighlightOrderConfirmedBy")
  marketplaceExposureEvents MarketplaceExposureEvent[] @relation("MarketplaceExposureViewer")
}

model Partner {
  id          String          @id @default(cuid())
  ownerUserId String
  owner       User            @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  name     String
  category PartnerCategory @default(OTHER)
  email    String?
  phone    String?
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehiclesAsInsurance Vehicle[] @relation("VehicleInsurancePartner")
  vehiclesAsWorkshop  Vehicle[] @relation("VehicleWorkshopPartner")
  vehiclesAsBodyshop  Vehicle[] @relation("VehicleBodyshopPartner")
  vehiclesAsParts     Vehicle[] @relation("VehiclePartsPartner")

  @@index([ownerUserId])
  @@index([ownerUserId, category])
  @@index([ownerUserId, name])
}

model OwnerProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  nomeRazaoSocial String @default("")
  emailLocador   String @default("")
  contractTemplateText String?
  cpfCnpj     String @default("")
  phone       String @default("")
  cep         String @default("")
  logradouro  String @default("")
  numero      String @default("")
  complemento String @default("")
  bairro      String @default("")
  cidade      String @default("")
  uf          String @default("")
  /** Média das avaliações recebidas (locatário → locador). Atualizada ao salvar avaliação. */
  averageRating Float @default(0)
  ratingCount   Int   @default(0)
}

model DriverProfile {
  id     String       @id @default(cuid())
  userId String       @unique
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  status DriverStatus @default(PENDING)
  /** Motivo informado pelo proprietário ao recusar o cadastro (cadastro aprovado/reaberto zera). */
  rejectionReason String?

  fullName    String?
  phone       String?
  cpf         String?
  cnh         String?
  cnhCategory String?
  cnhValidity String?
  cnhYears    Int?
  cnhHasEar   Boolean?
  criminalAttestation Boolean?
  uberRegistered Boolean?
  cep         String?
  logradouro  String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  uf          String?
  /** Média das avaliações recebidas (locador → locatário). Atualizada ao salvar avaliação. */
  averageRating Float @default(0)
  ratingCount   Int   @default(0)
}

model Vehicle {
  id               String   @id @default(cuid())
  ownerUserId      String
  owner            User     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  title            String
  description      String?
  plate            String
  brand            String?
  model            String?
  year             Int          @default(2010)
  cor              String?
  vehicleType      VehicleType  @default(CAR)
  portas           Int?
  lugares          Int?
  contractTime   ContractTime @default(DIARIO)
  kmLivre        Boolean  @default(false)
  kmPorContrato  Int      @default(0)
  insuranceMaintenanceIncluded Boolean @default(true)
  insurerPolicy  String?

  insurancePartnerId String?
  insurancePartner   Partner? @relation("VehicleInsurancePartner", fields: [insurancePartnerId], references: [id], onDelete: SetNull)

  workshopPartnerId String?
  workshopPartner   Partner? @relation("VehicleWorkshopPartner", fields: [workshopPartnerId], references: [id], onDelete: SetNull)

  bodyshopPartnerId String?
  bodyshopPartner   Partner? @relation("VehicleBodyshopPartner", fields: [bodyshopPartnerId], references: [id], onDelete: SetNull)

  partsPartnerId String?
  partsPartner   Partner? @relation("VehiclePartsPartner", fields: [partsPartnerId], references: [id], onDelete: SetNull)

  dailyRateCents   Int
  available        Boolean  @default(true)
  requirementsJson String?
  paymentNotes     String?
  caucao           String?
  pickupCity       String?
  pickupUf         String?

  pickupCep         String?
  pickupLogradouro  String?
  pickupNumero      String?
  pickupComplemento String?
  pickupBairro      String?
  pickupSameAsOwner Boolean  @default(false)

  highlightTier       VehicleHighlightTier @default(NORMAL)
  highlightExpiresAt  DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  photos  VehiclePhoto[]
  rentals Rental[]
  vehicleDriverBlocks VehicleDriverBlock[]
  highlightOrders     VehicleHighlightOrder[]
  marketplaceExposureEvents MarketplaceExposureEvent[]
}

model MarketplaceExposureEvent {
  id           String                       @id @default(cuid())
  eventId      String                       @unique
  vehicleId    String
  vehicle      Vehicle                      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  viewerUserId String?
  viewer       User?                        @relation("MarketplaceExposureViewer", fields: [viewerUserId], references: [id], onDelete: SetNull)
  placement    MarketplaceExposurePlacement @default(LIST)
  createdAt    DateTime                     @default(now())

  @@index([vehicleId, createdAt])
}

model HighlightPlan {
  id           String               @id @default(cuid())
  tier         VehicleHighlightTier @unique
  priceCents   Int                  @default(0)
  durationDays Int                  @default(30)
  active       Boolean              @default(false)
  description  String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model HighlightPlatformConfig {
  id           String     @id @default("default")
  pixKey       String     @default("")
  pixKeyType   PixKeyType @default(RANDOM)
  receiverName String     @default("")
  updatedAt    DateTime   @updatedAt
}

model VehicleHighlightOrder {
  id                   String                      @id @default(cuid())
  vehicleId            String
  vehicle              Vehicle                     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  ownerUserId          String
  owner                User                        @relation("HighlightOrderOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  tier                 VehicleHighlightTier
  status               VehicleHighlightOrderStatus @default(PENDING_PIX)
  amountCents          Int
  durationDaysSnapshot Int
  orderReference       String                      @unique
  paidAt               DateTime?
  confirmedByUserId    String?
  confirmedBy          User?                       @relation("HighlightOrderConfirmedBy", fields: [confirmedByUserId], references: [id], onDelete: SetNull)
  startsAt             DateTime?
  endsAt               DateTime?
  /** Quando o lembrete de expiração foi enviado ao locador (evita reenvio). */
  expiryReminderSentAt DateTime?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt

  @@index([status])
  @@index([ownerUserId])
  @@index([vehicleId])
  @@index([status, endsAt])
}

model VehicleDriverBlock {
  id           String   @id @default(cuid())
  vehicleId    String
  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driverUserId String
  driver       User     @relation(fields: [driverUserId], references: [id], onDelete: Cascade)
  /** true = proprietário recusou e ainda não desbloqueou */
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([vehicleId, driverUserId])
}

model VehiclePhoto {
  id          String   @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  key         String   @unique
  contentType String
  byteSize    Int
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

model Rental {
  id                 String       @id @default(cuid())
  vehicleId          String
  vehicle            Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driverUserId       String
  driver             User         @relation("DriverRentals", fields: [driverUserId], references: [id], onDelete: Cascade)
  status             RentalStatus @default(PENDING_OWNER)
  motivoRecusa       String?
  pickupInstructions String?
  contractText       String?
  contractS3Key      String?
  contractUrl        String?
  returnDate                    DateTime?
  situation                     RentalSituation @default(ATIVA)
  pendingReason                 String?
  pendingResolutionExpectedAt DateTime?
  requestedAt        DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  reviews RentalReview[]
  inspections RentalInspection[]
  financialSummary RentalFinancialSummary?
  financialEntries RentalFinancialEntry[]
}

model RentalFinancialSummary {
  id                   String              @id @default(cuid())
  rentalId             String              @unique
  rental               Rental              @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  agreedAmountCents    Int
  securityDepositCents Int?
  status               RentalPaymentStatus @default(PENDING)
  dueDate              DateTime?
  notes                String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([status])
}

model RentalFinancialEntry {
  id          String                   @id @default(cuid())
  rentalId    String
  rental      Rental                   @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  type        RentalFinancialEntryType
  amountCents Int
  method      RentalPaymentMethod?
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime                 @default(now())

  @@index([rentalId])
  @@index([type])
  @@index([paidAt])
}

model RentalInspection {
  id              String               @id @default(cuid())
  rentalId        String
  rental          Rental               @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  type            RentalInspectionType
  odometerKm      Int
  fuelLevel       FuelLevel
  notes           String?
  createdByUserId String
  createdBy       User                 @relation("InspectionCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  ownerAckAt      DateTime?
  ownerAckUserId  String?
  driverAckAt     DateTime?
  driverAckUserId String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  photos RentalInspectionPhoto[]

  @@unique([rentalId, type])
  @@index([rentalId])
  @@index([createdByUserId])
}

model RentalInspectionPhoto {
  id           String           @id @default(cuid())
  inspectionId String
  inspection   RentalInspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  key          String           @unique
  contentType  String
  byteSize     Int
  sortOrder    Int              @default(0)
  createdAt    DateTime         @default(now())

  @@index([inspectionId])
}

model RentalReview {
  id         String @id @default(cuid())
  rentalId   String
  rental     Rental @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  fromUserId String
  fromUser   User   @relation("ReviewFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  toUser     User   @relation("ReviewTo", fields: [toUserId], references: [id], onDelete: Cascade)

  direction ReviewDirection
  stars     Int
  tagsJson  Json?
  comment   String?

  createdAt DateTime @default(now())

  @@unique([rentalId, direction])
  @@index([toUserId])
  @@index([fromUserId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
}

/** Inventário de anúncios da plataforma (não confundir com Partner CRM do locador). */
model AdCampaign {
  id        String           @id @default(cuid())
  status    AdCampaignStatus @default(DRAFT)
  title     String
  subtitle  String?
  imageUrl  String?
  ctaLabel  String           @default("Saiba mais")
  clickUrl  String

  placements    AdPlacementKey[]
  targetRoles   Role[]
  targetUfs     String[]         @default([])
  targetCidades String[]         @default([])
  nationwide    Boolean          @default(false)
  priority      Int              @default(0)

  startsAt DateTime?
  endsAt   DateTime?

  /** Opcional: referência ao Partner CRM (sem expor dados privados na API). */
  sourcePartnerId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events AdEvent[]

  @@index([status, priority])
}

model AdEvent {
  id         String          @id @default(cuid())
  eventId    String          @unique
  campaignId String?
  campaign   AdCampaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  userId     String?
  placement  AdPlacementKey
  eventType  AdEventType
  platform   String?

  createdAt DateTime @default(now())

  @@index([campaignId, eventType])
  @@index([userId, createdAt])
}
