generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  DRIVER
}

enum DriverStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RentalStatus {
  PENDING_OWNER
  APPROVED
  REJECTED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum RentalSituation {
  ATIVA
  LIBERADA
  PENDENTE
}

enum RentalInspectionType {
  CHECKOUT
  CHECKIN
}

enum FuelLevel {
  EMPTY
  QUARTER
  HALF
  THREE_QUARTERS
  FULL
}

enum ContractTime {
  DIARIO
  SEMANAL
  MENSAL
}

enum PartnerCategory {
  INSURANCE
  WORKSHOP
  BODYSHOP
  PARTS
  OTHER
}

/** Locador avalia o motorista ou o contrário (uma avaliação por direção por locação). */
enum ReviewDirection {
  OWNER_TO_DRIVER
  DRIVER_TO_OWNER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())
  /** Versão da política de privacidade aceita pelo usuário (ex.: "1"). */
  privacyPolicyVersion    String    @default("")
  privacyPolicyAcceptedAt DateTime?

  ownerProfile  OwnerProfile?
  driverProfile DriverProfile?
  vehicles      Vehicle[]
  rentals       Rental[]      @relation("DriverRentals")
  vehicleDriverBlocks VehicleDriverBlock[]
  resetTokens   PasswordResetToken[]
  partners      Partner[]
  reviewsFrom   RentalReview[] @relation("ReviewFrom")
  reviewsTo     RentalReview[] @relation("ReviewTo")
  createdInspections RentalInspection[] @relation("InspectionCreatedBy")
}

model Partner {
  id          String          @id @default(cuid())
  ownerUserId String
  owner       User            @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  name     String
  category PartnerCategory @default(OTHER)
  email    String?
  phone    String?
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehiclesAsInsurance Vehicle[] @relation("VehicleInsurancePartner")
  vehiclesAsWorkshop  Vehicle[] @relation("VehicleWorkshopPartner")
  vehiclesAsBodyshop  Vehicle[] @relation("VehicleBodyshopPartner")
  vehiclesAsParts     Vehicle[] @relation("VehiclePartsPartner")

  @@index([ownerUserId])
  @@index([ownerUserId, category])
  @@index([ownerUserId, name])
}

model OwnerProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  nomeRazaoSocial String @default("")
  emailLocador   String @default("")
  contractTemplateText String?
  cpfCnpj     String @default("")
  phone       String @default("")
  cep         String @default("")
  logradouro  String @default("")
  numero      String @default("")
  complemento String @default("")
  bairro      String @default("")
  cidade      String @default("")
  uf          String @default("")
  /** Média das avaliações recebidas (locatário → locador). Atualizada ao salvar avaliação. */
  averageRating Float @default(0)
  ratingCount   Int   @default(0)
}

model DriverProfile {
  id     String       @id @default(cuid())
  userId String       @unique
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  status DriverStatus @default(PENDING)
  /** Motivo informado pelo proprietário ao recusar o cadastro (cadastro aprovado/reaberto zera). */
  rejectionReason String?

  fullName    String?
  phone       String?
  cpf         String?
  cnh         String?
  cnhCategory String?
  cnhValidity String?
  cnhYears    Int?
  cnhHasEar   Boolean?
  criminalAttestation Boolean?
  uberRegistered Boolean?
  cep         String?
  logradouro  String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  uf          String?
  /** Média das avaliações recebidas (locador → locatário). Atualizada ao salvar avaliação. */
  averageRating Float @default(0)
  ratingCount   Int   @default(0)
}

model Vehicle {
  id               String   @id @default(cuid())
  ownerUserId      String
  owner            User     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  title            String
  description      String?
  plate            String
  brand            String?
  model            String?
  year             Int          @default(2010)
  cor              String?
  portas           Int          @default(4)
  lugares          Int          @default(5)
  contractTime   ContractTime @default(DIARIO)
  kmLivre        Boolean  @default(false)
  kmPorContrato  Int      @default(0)
  insuranceMaintenanceIncluded Boolean @default(true)
  insurerPolicy  String?

  insurancePartnerId String?
  insurancePartner   Partner? @relation("VehicleInsurancePartner", fields: [insurancePartnerId], references: [id], onDelete: SetNull)

  workshopPartnerId String?
  workshopPartner   Partner? @relation("VehicleWorkshopPartner", fields: [workshopPartnerId], references: [id], onDelete: SetNull)

  bodyshopPartnerId String?
  bodyshopPartner   Partner? @relation("VehicleBodyshopPartner", fields: [bodyshopPartnerId], references: [id], onDelete: SetNull)

  partsPartnerId String?
  partsPartner   Partner? @relation("VehiclePartsPartner", fields: [partsPartnerId], references: [id], onDelete: SetNull)

  dailyRateCents   Int
  available        Boolean  @default(true)
  requirementsJson String?
  paymentNotes     String?
  caucao           String?
  pickupCity       String?
  pickupUf         String?

  pickupCep         String?
  pickupLogradouro  String?
  pickupNumero      String?
  pickupComplemento String?
  pickupBairro      String?
  pickupSameAsOwner Boolean  @default(false)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  photos  VehiclePhoto[]
  rentals Rental[]
  vehicleDriverBlocks VehicleDriverBlock[]
}

model VehicleDriverBlock {
  id           String   @id @default(cuid())
  vehicleId    String
  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driverUserId String
  driver       User     @relation(fields: [driverUserId], references: [id], onDelete: Cascade)
  /** true = proprietário recusou e ainda não desbloqueou */
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([vehicleId, driverUserId])
}

model VehiclePhoto {
  id          String   @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  key         String   @unique
  contentType String
  byteSize    Int
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

model Rental {
  id                 String       @id @default(cuid())
  vehicleId          String
  vehicle            Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driverUserId       String
  driver             User         @relation("DriverRentals", fields: [driverUserId], references: [id], onDelete: Cascade)
  status             RentalStatus @default(PENDING_OWNER)
  motivoRecusa       String?
  pickupInstructions String?
  contractText       String?
  contractS3Key      String?
  contractUrl        String?
  returnDate                    DateTime?
  situation                     RentalSituation @default(ATIVA)
  pendingReason                 String?
  pendingResolutionExpectedAt DateTime?
  requestedAt        DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  reviews RentalReview[]
  inspections RentalInspection[]
}

model RentalInspection {
  id              String               @id @default(cuid())
  rentalId        String
  rental          Rental               @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  type            RentalInspectionType
  odometerKm      Int
  fuelLevel       FuelLevel
  notes           String?
  createdByUserId String
  createdBy       User                 @relation("InspectionCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  ownerAckAt      DateTime?
  ownerAckUserId  String?
  driverAckAt     DateTime?
  driverAckUserId String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  photos RentalInspectionPhoto[]

  @@unique([rentalId, type])
  @@index([rentalId])
  @@index([createdByUserId])
}

model RentalInspectionPhoto {
  id           String           @id @default(cuid())
  inspectionId String
  inspection   RentalInspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  key          String           @unique
  contentType  String
  byteSize     Int
  sortOrder    Int              @default(0)
  createdAt    DateTime         @default(now())

  @@index([inspectionId])
}

model RentalReview {
  id         String @id @default(cuid())
  rentalId   String
  rental     Rental @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  fromUserId String
  fromUser   User   @relation("ReviewFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  toUser     User   @relation("ReviewTo", fields: [toUserId], references: [id], onDelete: Cascade)

  direction ReviewDirection
  stars     Int
  tagsJson  Json?
  comment   String?

  createdAt DateTime @default(now())

  @@unique([rentalId, direction])
  @@index([toUserId])
  @@index([fromUserId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
}
