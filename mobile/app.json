{
  "expo": {
    "name": "União LocaCar",
    "slug": "projeto-uniao-locacar",
    "version": "1.0.0",
    "scheme": "uniaolocacar",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#003366",
        "foregroundImage": "./assets/icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.claudirc.projetouniaolocacar"
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir acesso às fotos para cadastrar imagens do veículo."
        }
      ],
      "expo-sharing",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#003366"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "70ba6971-e4d2-4eb9-a3ec-b8918c0ed3c3"
      }
    }
  }
}
