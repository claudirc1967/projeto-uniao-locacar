{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "npx expo start --host lan",
    "android": "npx expo start --android --host lan",
    "preios": "open -a Simulator 2>/dev/null; xcrun simctl boot \"iPhone 17 Pro\" 2>/dev/null || xcrun simctl boot \"iPhone 17\" 2>/dev/null || true; xcrun simctl bootstatus booted -b && sh scripts/ensure-expo-go-ios.sh",
    "install-expo-go": "sh scripts/ensure-expo-go-ios.sh",
    "ios": "EXPO_OFFLINE=1 REACT_NATIVE_PACKAGER_HOSTNAME=127.0.0.1 npx expo start --ios --lan",
    "start:ios": "EXPO_OFFLINE=1 REACT_NATIVE_PACKAGER_HOSTNAME=127.0.0.1 npx expo start --lan",
    "web": "npx expo start --web",
    "predeploy": "npx expo export -p web && node scripts/copy-static-web.mjs",
    "deploy": "gh-pages --nojekyll -d dist",
    "eas:android": "eas build -p android --profile preview",
    "eas:ios": "eas build -p ios --profile preview"
  },
  "dependencies": {
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.5",
    "@tanstack/react-query": "^4.43.0",
    "@trpc/client": "^10.45.4",
    "@trpc/react-query": "^10.45.4",
    "expo": "~55.0.24",
    "expo-clipboard": "~55.0.13",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.11",
    "expo-image-picker": "~55.0.20",
    "expo-secure-store": "~55.0.14",
    "expo-sharing": "~55.0.19",
    "expo-status-bar": "~55.0.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-image-viewing": "^0.2.2",
    "react-native-paper": "^5.15.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "superjson": "^2.2.6"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "gh-pages": "^6.3.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
